{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "https://raw.githubusercontent.com/phac-nml/submitdatairidanext/main/assets/schema_input.json",
    "title": "phac-nml/submitdatairidanext pipeline - params.input schema",
    "description": "Schema for the file provided with params.input",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "sample": {
                "type": "string",
                "pattern": "^\\S+$",
                "meta": ["irida_id"],
                "unique": true,
                "errorMessage": "Sample name must be provided and cannot contain spaces"
            },
            "fastq_1": {
                "type": "string",
                "pattern": "^\\S+\\.f(ast)?q(\\.gz)?$",
                "errorMessage": "FastQ file for reads 1 must be provided, cannot contain spaces and must have the extension: '.fq', '.fastq', '.fq.gz' or '.fastq.gz'"
            },
            "fastq_2": {
                "errorMessage": "FastQ file for reads 2 cannot contain spaces and must have the extension: '.fq', '.fastq', '.fq.gz' or '.fastq.gz'",
                "anyOf": [
                    {
                        "type": "string",
                        "pattern": "^\\S+\\.f(ast)?q(\\.gz)?$"
                    },
                    {
                        "type": "string",
                        "maxLength": 0
                    }
                ]
            },
            "bioproject_accession": {
                "type": "string",
                "pattern": "^PRJ[A-Z]{2}\\d+$",
                "description": "BioProject accession",
                "meta": ["bioproject_accession"],
                "errorMessage": "Provide a valid BioProject accession."
            },
            "biosample_accession": {
                "type": "string",
                "pattern": "^SAMN\\d+$",
                "description": "BioSample accession",
                "meta": ["biosample_accession"],
                "errorMessage": "Provide a valid BioSample accession."
            },
            "library_source": {
                "type": "string",
                "enum": [
                    "GENOMIC",
                    "GENOMIC SINGLE CELL",
                    "TRANSCRIPTOMIC",
                    "TRANSCRIPTOMIC SINGLE CELL",
                    "METAGENOMIC",
                    "METATRANSCRIPTOMIC",
                    "SYNTHETIC",
                    "VIRAL RNA",
                    "OTHER"
                ],
                "description": "Library source type",
                "meta": ["library_source"],
                "default": "GENOMIC",
                "errorMessage": "Library source must be one of: GENOMIC, TRANSCRIPTOMIC, METAGENOMIC, GENOMIC SINGLE CELL, TRANSCRIPTOMIC SINGLE CELL, SYNTHETIC, VIRAL RNA, or OTHER"
            },
            "library_selection": {
                "type": "string",
                "enum": [
                    "RANDOM",
                    "PCR",
                    "RANDOM PCR",
                    "RT-PCR",
                    "HMPR",
                    "MF",
                    "repeat fractionation",
                    "size fractionation",
                    "MSLL",
                    "cDNA",
                    "cDNA_randomPriming",
                    "cDNA_oligo_dT",
                    "PolyA",
                    "Oligo-dT",
                    "Inverse rRNA",
                    "Inverse rRNA selection",
                    "ChIP",
                    "ChIP-Seq",
                    "MNase",
                    "DNase",
                    "Hybrid Selection",
                    "Reduced Representation",
                    "Restriction Digest",
                    "5-methylcytidine antibody",
                    "MBD2 protein methyl-CpG binding domain",
                    "CAGE",
                    "RACE",
                    "MDA",
                    "padlock probes capture method",
                    "other",
                    "unspecified"
                ],
                "description": "Library selection method",
                "meta": ["library_selection"],
                "default": "RANDOM",
                "errorMessage": "Library selection must be one of: RANDOM, PCR, RT-PCR, HMPR, MF, repeat fractionation, size fractionation, MSLL, cDNA, cDNA_randomPriming, cDNA_oligo_dT, PolyA, Oligo-dT, Inverse rRNA, Inverse rRNA selection, ChIP, ChIP-Seq, MNase, DNase, Hybrid Selection, Reduced Representation, Restriction Digest, 5-methylcytidine antibody, MBD2 protein methyl-CpG binding domain, CAGE, RACE, MDA, padlock probes capture method, other, or unspecified"
            },
            "library_strategy": {
                "type": "string",
                "enum": [
                    "WGS",
                    "WGA",
                    "WXS",
                    "RNA-Seq",
                    "ssRNA-seq",
                    "snRNA-seq",
                    "miRNA-seq",
                    "ncRNA-seq",
                    "FL-cDNA",
                    "EST",
                    "Hi-C",
                    "ATAC-seq",
                    "WCS",
                    "RAD-seq",
                    "CLONE",
                    "POOLCLONE",
                    "AMPLICON",
                    "CLONEEND",
                    "FINISHING",
                    "ChIP-Seq",
                    "MNase-Seq",
                    "DNase-Hypersensitivity",
                    "Bisulfite-Seq",
                    "CTS",
                    "MRE-Seq",
                    "MeDIP-Seq",
                    "MBD-Seq",
                    "Tn-Seq",
                    "VALIDATION",
                    "FAIRE-Seq",
                    "SELEX",
                    "RIP-Seq",
                    "ChIA-PET",
                    "Synthetic-Long-Read",
                    "Targeted-Capture",
                    "Tethered Chromatin Conformation Capture",
                    "NOMe-Seq",
                    "ChM-Seq",
                    "GBS",
                    "Ribo-Seq",
                    "OTHER"
                ],
                "description": "Library strategy. see: http://ftp.ebi.ac.uk/pub/databases/ena/doc/xsd/sra_1_5/SRA.experiment.xsd",
                "meta": ["library_strategy"],
                "default": "WGS",
                "errorMessage": "Library strategy must be one of: WGS, WES, RNA-Seq, or other"
            },
            "platform": {
                "type": "string",
                "enum": ["ILLUMINA", "PACBIO_SMRT", "ION_TORRENT", "OXFORD_NANOPORE", "SOLID", "OTHER"],
                "description": "Sequencing platform used for the library",
                "meta": ["platform"],
                "default": "ILLUMINA",
                "errorMessage": "Platform must be one of: ILLUMINA, PACBIO_SMRT, ION_TORRENT, OXFORD_NANOPORE, SOLID, or OTHER"
            },
            "instrument_model": {
                "type": "string",
                "enum": [
                    "HiSeq X Five",
                    "HiSeq X Ten",
                    "Illumina Genome Analyzer",
                    "Illumina Genome Analyzer II",
                    "Illumina Genome Analyzer IIx",
                    "Illumina HiScanSQ",
                    "Illumina HiSeq 1000",
                    "Illumina HiSeq 1500",
                    "Illumina HiSeq 2000",
                    "Illumina HiSeq 2500",
                    "Illumina HiSeq 3000",
                    "Illumina HiSeq 4000",
                    "Illumina HiSeq X",
                    "Illumina iSeq 100",
                    "Illumina MiSeq",
                    "Illumina MiniSeq",
                    "Illumina NovaSeq X",
                    "Illumina NovaSeq X Plus",
                    "Illumina NovaSeq 6000",
                    "NextSeq 500",
                    "NextSeq 550",
                    "NextSeq 1000",
                    "NextSeq 2000",
                    "MinION",
                    "GridION",
                    "PromethION",
                    "Onso",
                    "PacBio RS",
                    "PacBio RS II",
                    "Revio",
                    "Sequel",
                    "Sequel II",
                    "Sequel IIe",
                    "Vega",
                    "unspecified"
                ],
                "description": "Model of sequencing instrument used for the library",
                "meta": ["instrument_model"],
                "default": "Illumina MiSeq",
                "errorMessage": "Sequencing instrument model must be one of: HiSeq X Five, HiSeq X Ten, Illumina Genome Analyzer, Illumina Genome Analyzer II, Illumina Genome Analyzer IIx, Illumina HiScanSQ, Illumina HiSeq 1000, Illumina HiSeq 1500, Illumina HiSeq 2000, Illumina HiSeq 2500, Illumina HiSeq 3000, Illumina HiSeq 4000, Illumina HiSeq X, Illumina iSeq 100, Illumina MiSeq, Illumina MiniSeq, Illumina NovaSeq X, Illumina NovaSeq X Plus, Illumina NovaSeq 6000, NextSeq 500, NextSeq 550, NextSeq 1000, NextSeq 2000, MinION, GridION, PromethION, Onso, PacBio RS, PacBio RS II, Revio, Sequel, Sequel II, Sequel IIe or Vega"
            }
        },
        "required": [
            "sample",
            "fastq_1",
            "bioproject_accession",
            "biosample_accession",
            "library_source",
            "library_selection",
            "library_strategy",
            "platform",
            "instrument_model"
        ]
    }
}
