nextflow_process {

    name "Test Process CREATE_ENA_UPLOAD_MANIFEST"
    script "modules/local/create_ena_upload_manifest/main.nf"
    process "CREATE_ENA_UPLOAD_MANIFEST"

    test("Basic execution, check output.") {

        when {
            params {
                outdir = "tests/results"
            }
            process {
                """
                input[0] = new Tuple(["id": "SAMPLE1", "irida_id": "SAMPLE1", "bioproject_accession": "PRJNA123456", "biosample_accession": "SAMN12345678"], [file("$baseDir/tests/data/SAMPLE1_R1.fastq.gz"), file("$baseDir/tests/data/SAMPLE1_R2.fastq.gz")])
                """
            }
        }

        then {
            assert process.success
            with(process.out) {
                // parse output json file
                def json_string = path(upload_manifest.get(0)[1]).getText()
                def parser = new groovy.json.JsonSlurper()
                def json_manifest = parser.parseText(json_string)
                assert json_manifest.study == "PRJNA123456"
                assert json_manifest.sample == "SAMN12345678"
                assert json_manifest.library_name == "SAMPLE1"
                assert json_manifest.fastq[0].value == "SAMPLE1_R1.fastq.gz"
                assert json_manifest.fastq[1].value == "SAMPLE1_R2.fastq.gz"
            }
        }
    }
}
