nextflow_process {

    name "Test Process CREATE_SRA_SUBMISSION_XML"
    script "modules/local/create_sra_submission_xml/main.nf"
    process "CREATE_SRA_SUBMISSION_XML"

    test("Basic execution, check output.") {

        when {
            params {
                outdir = "output"
            }
            process {
                """
                input[0] = [file("$baseDir/tests/data/SAMPLE1_sra_addfiles.xml")]
                """
            }
        }

        then {
            assert process.success
            with(process.out) {
                def xmlString = path(submission_xml[0]).getText()
                def parser = new groovy.xml.XmlSlurper()
                def xmlManifestRootNode = parser.parseText(xmlString)

                assert xmlManifestRootNode.name() == 'Submission'
            }
        }

    }
}
