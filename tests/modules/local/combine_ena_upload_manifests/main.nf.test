nextflow_process {
    name "Test Process COMBINE_ENA_UPLOAD_MANIFESTS"
    script "modules/local/combine_ena_upload_manifests/main.nf"
    process "COMBINE_ENA_UPLOAD_MANIFESTS"

    test("Basic execution.") {

        when {
            params {
                outdir = "output"
            }
            process {
                """
                input[0] = [file("$baseDir/tests/data/SAMPLE1_ena_upload_manifest.json"), file("$baseDir/tests/data/SAMPLE2_ena_upload_manifest.json")]
                """
            }
        }

        then {
            assert process.success
        }
    }
}
