iridanext {
    enabled = true
    output {
        path = "${params.outdir}/iridanext.output.json.gz"
        overwrite = true
        files {
            global = [
                "**/create_sra_submission_xml/submission.xml",
                "**/upload_checker/errors.csv",
            ]
            samples = [
                "**/upload_reads_to_sra/*_sra_upload.log.txt",
                "**/create_sra_addfiles_xml/*_sra_addfiles.xml",
                "**/upload_reads_to_ena/*_ena_upload.log.txt",
                "**/create_ena_upload_manifest/*_ena_upload_manifest.json",
            ]
        }
        metadata {
            samples {
                json {
                    path = "**/append_errors_to_upload_metadata/metadata.json"
                }
            }
        }
    }
}
